# Bot environment configuration
# Copy this file to .env and fill in the values
#
# Recommended: create 3 separate bots in @BotFather:
#   @FitCoachLocalBot  — for local development
#   @FitCoachDevBot    — for dev VPS
#   @FitCoachBot       — for production VPS
# This avoids polling conflicts when multiple instances run

TELEGRAM_TOKEN=
SERVER_URL=http://localhost:3000
BOT_API_KEY=
