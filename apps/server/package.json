{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "NODE_ENV=test jest",
    "test:unit": "NODE_ENV=test jest --testMatch='**/__tests__/**/*.unit.test.ts' --testMatch='**/src/**/*.unit.test.ts'",
    "test:integration": "RUN_DB_TESTS=1 NODE_ENV=test jest --testMatch='**/tests/integration/**/*.integration.test.ts'",
    "test:e2e": "RUN_E2E=1 NODE_ENV=test jest --testMatch='**/tests/e2e/**/*.e2e.test.ts'",
    "test:coverage": "NODE_ENV=test jest --coverage",
    "test:coverage:unit": "NODE_ENV=test jest --testMatch='**/__tests__/**/*.unit.test.ts' --testMatch='**/src/**/*.unit.test.ts' --coverage",
    "test:coverage:integration": "RUN_DB_TESTS=1 NODE_ENV=test jest --testMatch='**/tests/integration/**/*.integration.test.ts' --coverage",
    "test:coverage:e2e": "RUN_E2E=1 NODE_ENV=test jest --testMatch='**/tests/e2e/**/*.e2e.test.ts' --coverage",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:watch:unit": "NODE_ENV=test jest --testMatch='**/__tests__/**/*.unit.test.ts' --testMatch='**/src/**/*.unit.test.ts' --watch",
    "test:watch:integration": "RUN_DB_TESTS=1 NODE_ENV=test jest --testMatch='**/tests/integration/**/*.integration.test.ts' --watch",
    "run-server": "node dist/index.js",
    "dev": "mkdir -p ../../logs && tsx watch --env-file=.env src/index.ts 2>&1 | tee -a ../../logs/server.log",
    "db:local:up": "docker compose -f ../../docker-compose.yml up -d db",
    "db:local:migrate": "docker compose -f ../../docker-compose.yml --profile migrate run --rm migrate",
    "db:local:fresh": "docker compose -f ../../docker-compose.yml down && rm -rf ../../data/local/postgres && docker compose -f ../../docker-compose.yml up -d db && sleep 5 && docker exec fitcoach-db psql -U postgres -c 'CREATE DATABASE fitcoach_dev;' && docker exec fitcoach-db psql -U postgres -d fitcoach_dev -c 'CREATE EXTENSION IF NOT EXISTS vector;' && npm run db:local:migrate && npm run db:seed:exercises",
    "db:dev:fresh": "npm run db:reset:dev && npm run drizzle:push && npm run db:seed:exercises",
    "db:reset:dev": "docker exec fitcoach-db psql -U postgres -c \"DROP DATABASE IF EXISTS fitcoach_dev WITH (FORCE);\" && docker exec fitcoach-db psql -U postgres -c \"CREATE DATABASE fitcoach_dev;\"",
    "db:prod:migrate": "NODE_ENV=production drizzle-kit push",
    "db:prod:seed:exercises": "tsx --env-file=.env.production src/infra/db/seeds/exercises.seed.ts",
    "db:prod:backup": "mkdir -p ../../backups && docker exec fitcoach-db pg_dump -U postgres fitcoach > ../../backups/fitcoach_prod_$(date +%Y%m%d_%H%M%S).sql && echo \"Backup saved to backups/fitcoach_prod_$(date +%Y%m%d_%H%M%S).sql\"",
    "drizzle:push": "NODE_ENV=development drizzle-kit push",
    "drizzle:generate": "NODE_ENV=test drizzle-kit generate",
    "drizzle:studio": "drizzle-kit studio",
    "drizzle:reset": "NODE_ENV=test drizzle-kit drop && NODE_ENV=test drizzle-kit push",
    "db:clean": "NODE_ENV=test tsx src/db/clean.ts",
    "db:seed:exercises": "tsx --env-file=.env src/infra/db/seeds/exercises.seed.ts",
    "db:seed:workouts": "tsx --env-file=.env src/infra/db/seeds/workouts.seed.ts",
    "db:cleanup-orphan-checkpoints": "tsx --env-file=.env src/infra/db/scripts/cleanup-orphan-checkpoints.ts",
    "db:sync": "tsx --env-file=.env src/infra/db/scripts/sync-user-data.ts",
    "build": "rimraf dist && tsup src/index.ts --format esm --dts --sourcemap --out-dir dist --clean",
    "start": "node --env-file=.env.production dist/index.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "lint:file": "eslint",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "type-check": "tsc --noEmit",
    "check-all": "npm run lint && npm run format:check && npm run type-check",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.15.5",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.35.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^3.1.0",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "jest": "^30.1.1",
    "lint-staged": "^16.1.6",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.1",
    "tsup": "^8.1.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.27.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/sensible": "^6.0.3",
    "@fastify/static": "^8.2.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@huggingface/transformers": "^3.8.1",
    "@langchain/core": "^1.1.27",
    "@langchain/langgraph": "^1.1.5",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.1",
    "@langchain/openai": "^1.2.9",
    "dotenv": "^17.2.1",
    "drizzle-orm": "^0.44.5",
    "fastify": "^5.5.0",
    "fastify-type-provider-zod": "^5.1.0",
    "pg": "^8.16.3",
    "pgvector": "^0.2.1",
    "pino": "^9.9.0",
    "pino-pretty": "^13.1.1",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1"
  }
}
