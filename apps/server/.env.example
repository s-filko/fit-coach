# Server environment configuration
# Copy this file to .env and fill in the values
# See docs/DB_SETUP.md for detailed setup instructions

NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=fitcoach

# API authentication (shared secret between server and bot)
BOT_API_KEY=

# LLM provider (any OpenAI-compatible API: OpenAI, OpenRouter, Groq, etc.)
LLM_API_KEY=
LLM_API_URL=
LLM_MODEL=
LLM_TEMPERATURE=0.7

# Docker deploy only (not needed for local dev)
# Name of the Docker network used by Nginx Proxy Manager
# Find it with: docker network ls
NPM_NETWORK=nginx-proxy-manager_default
